<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CarAILauncher" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_light_start</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:buttonStyle">@style/AppButtonBase</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/background_light_end</item>
        <item name="colorAccent">@color/accent_green</item>
    </style>

    <!-- 深色主题 -->
    <style name="Theme.CarAILauncher.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/background_dark_start</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:buttonStyle">@style/AppButtonBase.Dark</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/background_dark_end</item>
        <item name="colorAccent">@color/accent_green</item>
    </style>

    <!-- 深色对话框主题 -->
    <style name="Theme.CarAILauncher.Dark.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/dark_card_bg</item>
        <item name="android:textColor">@color/dark_text_primary</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="AppButtonBase" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:background">@drawable/bg_button_ghost</item>
    </style>

    <style name="AppButtonBase.Dark" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:background">@drawable/bg_button_ghost</item>
    </style>

    <style name="StatusChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_glass_chip</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textColor">@color/text_secondary_light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="DockIcon">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:background">@drawable/bg_dock_icon</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary_light</item>
    </style>

    <style name="QuickButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/bg_ios_button</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="QuickButton.Dark">
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>

    <style name="MusicControlButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_ios_button</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary_light</item>
    </style>

    <style name="MusicControlButton.Dark">
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>

    <style name="HeroPrimaryButton" parent="AppButtonBase">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="HeroPrimaryButton.Dark" parent="AppButtonBase.Dark">
        <item name="android:background">@drawable/bg_button_primary</item>
    </style>

    <style name="HeroPrimaryButtonSmall" parent="HeroPrimaryButton">
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="HeroPrimaryButtonSmall.Dark" parent="HeroPrimaryButton.Dark">
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="HeroSecondaryButton" parent="AppButtonBase">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="HeroSecondaryButton.Dark" parent="AppButtonBase.Dark">
        <item name="android:background">@drawable/bg_button_secondary</item>
    </style>

    <style name="TopActionButton" parent="AppButtonBase">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:background">@drawable/bg_button_ghost</item>
    </style>

    <style name="TopActionButton.Dark" parent="AppButtonBase.Dark">
        <item name="android:background">@drawable/bg_button_ghost</item>
    </style>

    <style name="TopPrimaryButton" parent="TopActionButton">
        <item name="android:background">@drawable/bg_button_primary</item>
    </style>

    <style name="TopPrimaryButton.Dark" parent="TopActionButton.Dark">
        <item name="android:background">@drawable/bg_button_primary</item>
    </style>

    <style name="MiniActionButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_button_ghost_small</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="MiniActionButton.Dark">
        <item name="android:textColor">@color/text_primary_dark</item>
    </style>

    <style name="MiniActionButtonFilled" parent="MiniActionButton">
        <item name="android:background">@drawable/bg_button_primary_small</item>
    </style>

    <style name="MiniActionButtonFilled.Dark" parent="MiniActionButton.Dark">
        <item name="android:background">@drawable/bg_button_primary_small</item>
    </style>

    <style name="DrawerTile">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/bg_app_drawer_item</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@drawable/bg_app_drawer_item</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="SettingsTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsDescription">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/text_secondary_light</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="SuggestionButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/bg_button_ghost</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="AvatarAmber">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_avatar_amber</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFD191</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AvatarBlue">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_avatar_blue</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#A6CCFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="QuickAddButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_add_button</item>
    </style>

    <style name="NavButton">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_nav_button</item>
    </style>

</resources>