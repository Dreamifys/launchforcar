<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="800dp"
    android:layout_height="600dp"
    android:orientation="vertical"
    android:background="@color/dark_bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/dark_card_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择悬浮应用"
            android:textColor="@color/dark_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/close_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_nav_button"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="关闭" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <EditText
            android:id="@+id/search_edit_text"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="搜索应用..."
            android:textColorHint="@color/dark_text_tertiary"
            android:textColor="@color/dark_text_primary"
            android:background="@drawable/bg_search_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <Spinner
            android:id="@+id/category_spinner"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="@color/dark_card_bg" />
    </LinearLayout>

    <ListView
        android:id="@+id/app_list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

</LinearLayout>