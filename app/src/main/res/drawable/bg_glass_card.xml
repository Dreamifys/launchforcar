<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底层模糊效果 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_glass_light" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- 高光描边 -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/border_hairline_light" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
